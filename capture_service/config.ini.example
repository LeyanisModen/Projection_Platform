; Copy this file to config.ini next to capture_service.py and edit
; the values for each mini-PC. Anything you do not set here falls back
; to the defaults baked into capture_service.py.

[service]
; HTTP server binding. Keep it on loopback so nothing external can hit it.
host = 127.0.0.1
port = 5555

; Camera index (first webcam = 0, second = 1, ...).
camera_index = 0

; On-demand /capture size. The OBSBOT Tiny 2 soporta 4K nativo pero
; el driver UVC se queda colgado en read() si le pides 3840x2160 nada
; más abrirla (sleep mode / warm-up). FullHD arranca estable en todos
; los mini-PCs probados y es suficiente para proyección de obra.
capture_width = 1920
capture_height = 1080
jpeg_quality = 95


[documentation]
; Set enabled = false to turn the periodic capture loop off entirely.
enabled = true

; Root folder that Google Drive Desktop is syncing. Each mini-PC should
; point to the same Google Drive mounted letter so everything lands in
; the shared corporate drive.
output_dir = G:\Mi unidad\capturas_moden

; Unique id per mesa (subfolder inside output_dir). Format is
; <cliente>_g<N>_<rol>, where <cliente> is a short client code
; (fer = Ferralia, …), <N> is the group number within that client
; and <rol> is inf1, inf2 or sup. Mirrors the computer name 1-to-1
; (FER-G1-INF1 ↔ fer_g1_inf1). Examples: fer_g1_inf1, fer_g1_sup,
; fer_g2_inf2.
mesa_id = fer_g1_inf1

; Seconds between captures. 3 s ~ 17k pictures per 14h shift (~8 GB/day
; at 350-500 KB/frame), which Drive syncs comfortably and still captures
; enough movement for documentation/marketing.
interval_seconds = 3

; Resolution + quality for the documentation images. FullHD at q=88
; comes out around 350-500 KB per frame.
width = 1920
height = 1080
jpeg_quality = 88

; Local disk cap for the documentation buffer. When the size of
; output_dir/<mesa_id> goes above this number, the oldest YYYY-MM-DD
; folders are dropped (today is never touched).
max_local_gb = 30

; Working window. Outside of it the loop sleeps and nothing is written.
active_days = MON,TUE,WED,THU,FRI
active_start_hour = 5
active_end_hour = 19


[sharpness]
; Once per active day (on the first tick of the morning) the service
; grabs a frame and runs a variance-of-Laplacian analysis on it. Low
; variance means soft edges, which on a fixed-focus camera points to
; a dirty lens. The result is exposed in /stats (sharpness_status) and
; the visor uses it to show an amber "Cámara sucia" warning on screen.
enabled = true

; Variance thresholds. Tune after observing real values on /stats:
;   > threshold_warning      -> status 'ok'
;   >= threshold_blurry      -> status 'warning' (borderline)
;   < threshold_blurry       -> status 'blurry' (likely dirty lens)
threshold_blurry = 50
threshold_warning = 150
